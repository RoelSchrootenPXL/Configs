<config xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">
    <!-- Task 7: Change Hostname -->
    <hostname>NetDevOps-Router</hostname>

    <interface>
      <!-- Task 3 & 36: GigabitEthernet1 met IP -->
      <GigabitEthernet>
        <name>1</name>
        <description>Configured via Python GUI</description>
        <ip>
          <address>
            <primary>
              <address>10.1.1.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
      </GigabitEthernet>
      <!-- Task 36: Tweede interface (bijv. GigabitEthernet2) -->
      <GigabitEthernet>
        <name>2</name>
        <ip>
          <address>
            <primary>
              <address>10.2.2.1</address>
              <mask>255.255.255.0</mask>
            </primary>
          </address>
        </ip>
      </GigabitEthernet>
    </interface>

    <!-- Task 27 & 36: OSPF Routing -->
    <router>
      <ospf xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-ospf">
        <id>1</id>
        <networks>
          <network>
            <ip>10.1.1.0</ip>
            <mask>0.0.0.255</mask>
            <area>0</area>
          </network>
          <network>
            <ip>10.2.2.0</ip>
            <mask>0.0.0.255</mask>
            <area>0</area>
          </network>
        </networks>
      </ospf>
    </router>
  </native>
</config>
