<config xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">
    <hostname>LAB-RA03-A01-SW01</hostname>
    
    <vlan>
      <vlan-list xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-vlan">
        <id>10</id><name>Management</name>
      </vlan-list>
      <vlan-list xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-vlan">
        <id>20</id><name>VM-Hosts</name>
      </vlan-list>
      <vlan-list xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-vlan">
        <id>40</id><name>Data-Users</name>
      </vlan-list>
    </vlan>

    <interface>
      <GigabitEthernet>
        <name>1/0/1</name>
        <description>Trunk to LAB-RA03-C01-R01</description>
        <switchport>
          <mode xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-switch">
            <trunk/>
          </mode>
          <trunk xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-switch">
            <allowed>
              <vlan>
                <vlans>10,20,30,40,99</vlans>
              </vlan>
            </allowed>
          </trunk>
          <nonegotiate xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-switch"/>
        </switchport>
      </GigabitEthernet>

      <GigabitEthernet>
        <name>1/0/2</name>
        <description>Data-Users access port</description>
        <switchport>
          <mode xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-switch">
            <access/>
          </mode>
          <access xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-switch">
            <vlan>
              <vlan>40</vlan>
            </vlan>
          </access>
        </switchport>
        <spanning-tree xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-spanning-tree">
          <portfast/>
          <bpduguard>
            <enable/>
          </bpduguard>
        </spanning-tree>
      </GigabitEthernet>

      <Vlan>
        <name>10</name>
        <ip>
          <address>
            <primary>
              <address>172.16.3.5</address>
              <mask>255.255.255.240</mask>
            </primary>
          </address>
        </ip>
      </Vlan>
    </interface>
  </native>
</config>
